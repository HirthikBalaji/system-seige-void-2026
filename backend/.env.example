# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- Postgres (local docker-compose) ---
POSTGRES_OWNER_PASSWORD=change-me-owner-password
APP_DB_PASSWORD=change-me-app-password

# Used only for `prisma migrate` and `npm run harden:db` — connects as the
# table-owning role (platform_owner). Never used by the running server.
MIGRATION_DATABASE_URL=postgresql://platform_owner:change-me-owner-password@localhost:5432/secrets_platform?schema=public

# Used by the running server. Connects as the restricted, non-owner app_user
# role so Row-Level Security policies actually apply (see docker/init and
# scripts/apply-db-hardening.ts for why this split matters).
DATABASE_URL=postgresql://app_user:change-me-app-password@localhost:5432/secrets_platform?schema=public

# --- Auth ---
# Must match exactly what the auth/gateway team uses to *sign* JWTs.
# Coordinate this value with them; never generate your own independently.
JWT_SECRET=replace-with-shared-jwt-signing-secret

# --- Vault envelope encryption ---
# 32-byte key encryption key, hex-encoded (64 hex chars). Generate with:
#   openssl rand -hex 32
# Rotating this requires re-wrapping every stored DEK — treat it as a
# long-lived secret, store it outside the repo (secrets manager in prod).
MASTER_KEK=replace-with-openssl-rand-hex-32-output

# --- AI scanner (BYOK) ---
# Real Anthropic API key. Never committed, never logged.
LLM_API_KEY=replace-with-your-anthropic-api-key

PORT=4000
NODE_ENV=development
