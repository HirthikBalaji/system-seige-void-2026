// Runtime datasource — resolves to app_user (non-owner, RLS-subject) in normal
// operation. `npm run migrate:dev` / `migrate:deploy` temporarily override
// DATABASE_URL to the owner connection via scripts/with-owner-db.mjs, because
// only the owning role can run DDL — see docker/init and prisma/hardening.sql
// for why the runtime role must NOT be the table owner.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Stub for local dev only — in the real deployment this table is owned and
// created by the auth/tenant service; we only ever reference tenant_id via FK.
model Tenant {
  id   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name String

  secrets               Secret[]
  certificates          Certificate[]
  auditLogs             AuditLog[]
  scanFindings          ScanFinding[]
  rotationLogs          RotationLog[]
  sandboxSessions       SandboxSession[]
  workloadIdentities    WorkloadIdentity[]
  autonomousRevocations AutonomousRevocation[]
  digitalTwinNodes      DigitalTwinNode[]
  digitalTwinEdges      DigitalTwinEdge[]
  blastRadiusSimulations BlastRadiusSimulation[]
  federatedModels       FederatedIntelligenceModel[]
  riskCards             RiskCard[]

  @@map("tenants")
}

model Secret {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  name           String
  encryptedValue Bytes     @map("encrypted_value")
  iv             Bytes
  authTag        Bytes     @map("auth_tag")
  wrappedDek     Bytes     @map("wrapped_dek")
  version        Int       @default(1)
  createdBy      String    @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  // AI Risk and Rotation Fields
  riskScore      Float     @default(0) @map("risk_score")
  riskLevel      String    @default("LOW") @map("risk_level")
  lastRotationTime DateTime @default(now()) @map("last_rotation_time") @db.Timestamptz(6)
  rotationFrequencyDays Int @default(90) @map("rotation_frequency_days")
  isRotatable    Boolean   @default(true) @map("is_rotatable")

  // Cryptographic Time-Lock fields
  expiresAt      DateTime? @map("expires_at") @db.Timestamptz(6)
  timeLockMetadata Json?   @map("time_lock_metadata")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("secrets")
}

model Certificate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String?
  commonName  String   @map("common_name")
  issuedAt    DateTime @map("issued_at") @db.Timestamptz(6)
  expiresAt   DateTime @map("expires_at") @db.Timestamptz(6)
  status      String   @default("active")
  autoRenew   Boolean  @default(true) @map("auto_renew")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("certificates")
}

model AuditLog {
  id           BigInt   @id @default(autoincrement())
  tenantId     String   @map("tenant_id") @db.Uuid
  actorId      String   @map("actor_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id") @db.Uuid
  details      Json     @default("{}")
  prevHash     String   @map("prev_hash") @db.Char(64)
  entryHash    String   @map("entry_hash") @db.Char(64)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, id])
  @@map("audit_log")
}

model ScanFinding {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  source         String
  secretType     String   @map("secret_type")
  matchedSnippet String   @map("matched_snippet")
  severity       String
  llmVerdict     String   @map("llm_verdict")
  remediation    String
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("scan_findings")
}

model RotationLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  secretId       String   @map("secret_id") @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  triggerType    String   @map("trigger_type") // AUTO or MANUAL
  oldVersion     Int      @map("old_version")
  newVersion     Int      @map("new_version")
  status         String   // PENDING, COMPLETED, FAILED
  riskScoreBefore Float    @map("risk_score_before")
  rotationReason String   @map("rotation_reason")
  riskFactors    Json     @map("risk_factors") @default("{}")
  aiConfidence   Float    @map("ai_confidence") @default(1.0)
  timeline       Json     @default("[]")
  errorLog       String?  @map("error_log")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("rotation_logs")
}

model SandboxSession {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  name                   String
  createdBy              String    @map("created_by") @db.Uuid
  status                 String    // ACTIVE, EXPIRED, DESTROYED
  resources              Json      @default("[]")
  expiresAt              DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  destroyedAt            DateTime? @map("destroyed_at") @db.Timestamptz(6)
  destructionCertificate String?   @map("destruction_certificate")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("sandbox_sessions")
}

model WorkloadIdentity {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  name            String
  type            String   // KUBERNETES, DOCKER, MICROSERVICE
  attestationType String   // K8S_SA, TPM, SPIFFE
  status          String   // ACTIVE, REVOKED
  selector        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  certificates    WorkloadCertificate[]
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("workload_identities")
}

model WorkloadCertificate {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workloadId      String    @map("workload_id") @db.Uuid
  serialNumber    String    @map("serial_number")
  commonName      String    @map("common_name")
  sans            Json      @default("[]")
  certificatePem  String    @map("certificate_pem")
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  status          String    // ACTIVE, REVOKED
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)
  revocationReason String?  @map("revocation_reason")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  workload        WorkloadIdentity @relation(fields: [workloadId], references: [id])

  @@index([workloadId])
  @@map("workload_certificates")
}

model AutonomousRevocation {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  findingId          String?   @map("finding_id") @db.Uuid
  provider           String    // AWS, GITHUB, STRIPE, TWILIO, GCP, AZURE
  credentialIdentifier String  @map("credential_identifier")
  status             String    // PENDING, VALIDATED, REVOKING, COMPLETED, FAILED
  executedActions    Json      @default("[]")
  rollbackPlan       String?   @map("rollback_plan")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant             Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("autonomous_revocations")
}

model DigitalTwinNode {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  type        String   // USER, SECRET, CERTIFICATE, APPLICATION, API, DATABASE, K8S_CLUSTER, CLOUD_RESOURCE, CICD_PIPELINE
  properties  Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("digital_twin_nodes")
}

model DigitalTwinEdge {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  sourceNodeId String   @map("source_node_id") @db.Uuid
  targetNodeId String   @map("target_node_id") @db.Uuid
  type         String   // ACCESSES, CONTAINS, MANAGES, DEPENDS_ON
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("digital_twin_edges")
}

model BlastRadiusSimulation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  secretId        String?  @map("secret_id") @db.Uuid
  startNodeId     String   @map("start_node_id") @db.Uuid
  riskScore       Float    @map("risk_score")
  compromisedNodes Json     @default("[]")
  lateralPaths    Json     @default("[]")
  businessImpact  String   @map("business_impact")
  recommendations Json     @default("[]")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("blast_radius_simulations")
}

model FederatedIntelligenceModel {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  patternType      String   @map("pattern_type") // SECRET_LEAK_LOCATION, FILE_TYPE, COMMIT_BEHAVIOR
  extractedPattern Json     @map("extracted_pattern")
  isShared         Boolean  @default(false) @map("is_shared")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("federated_intelligence_models")
}

model GlobalIntelligenceRule {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleName    String   @map("rule_name")
  pattern     String
  severity    String
  sourceCount Int      @map("source_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("global_intelligence_rules")
}

model RiskCard {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  targetType         String   @map("target_type") // SECRET, CERTIFICATE, WORKLOAD
  targetId           String   @map("target_id")
  riskScore          Float    @map("risk_score")
  confidenceScore    Float    @map("confidence_score")
  triggerEvent       String   @map("trigger_event")
  evidence           Json     @default("{}")
  timeline           Json     @default("[]")
  assetsAffected     Json     @default("[]")
  businessImpact     String   @map("business_impact")
  complianceImpact   String   @map("compliance_impact")
  recommendedAction  String   @map("recommended_action")
  executedAction     String   @map("executed_action")
  validationPerformed String   @map("validation_performed")
  rollbackPlan       String   @map("rollback_plan")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant             Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("risk_cards")
}


