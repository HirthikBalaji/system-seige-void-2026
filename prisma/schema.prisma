// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// This app is the auth/session/tenant gateway in front of the real
// secrets/certs/audit-log/scanner backend (see /backend — a separate
// Express + Postgres service). Secret/Certificate/AuditLog resource data
// used to live here too; it's now owned entirely by that backend (real
// envelope encryption, RLS-enforced tenant isolation, a hash-chained audit
// trail) and proxied to via src/lib/backendClient.ts. Only auth-adjacent
// state stays in this SQLite database.
model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model User {
  id        String    @id // Cloudflare User ID / Subject (sub)
  email     String    @unique
  name      String?
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      String    // SUPER_ADMIN, ORG_ADMIN, SECURITY_ADMIN, DEVELOPER, AUDITOR, READ_ONLY, SERVICE_ACCOUNT
  status    String    // ACTIVE, SUSPENDED
  lastLogin DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  auditLogs AuditLog[]
  sessions  Session[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Auth-event trail only (login, logout, permission-denied) — kept separate
// from the backend's resource audit trail (secret.create, cert.renew, etc.),
// which is hash-chained and tenant-scoped over there instead.
model AuditLog {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String?
  tenantId  String?
  ipAddress String
  userAgent String
  action    String
  result    String   // SUCCESS, FAILURE, DENIED
  details   String   // JSON string of metadata
  prevHash  String
  rowHash   String
  signature String
}
